{
	"name": "n8n-nodes-gitea-forgejo",
	"version": "0.1.3",
	"description": "n8n community node for Gitea and Forgejo.",
	"license": "MIT",
	"homepage": "https://github.com/raphaelbarreiros/n8n-nodes-gitea-forgejo",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"gitea",
		"forgejo"
	],
	"author": {
		"name": "Raphael Barreiros",
		"email": "barreiros.raphael@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/raphaelbarreiros/n8n-nodes-gitea-forgejo.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/GiteaForgejoApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/GiteaForgejo/GiteaForgejo.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
